# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<add api here>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Apify (remote GitHub repo ingestion) ──────────────────────────────────────
# Without APIFY_API_TOKEN + APIFY_ACTOR_ID, POST /repos/import falls back to
# direct GitHub API for public repos. 503 only if the GitHub API fetch itself fails.
APIFY_API_TOKEN=apify_api_...
APIFY_ACTOR_ID=username/filemind-repo-importer
GITHUB_TOKEN=ghp_...                  # Optional — raises GitHub rate limit 60->5000/hr

# ── Zynd AI x402 (micropayment middleware) ────────────────────────────────────
# X402_ENABLED=false (default): all requests pass through, no payment required.
# X402_ENABLED=true: POST /query, GET /query/stream, POST /repos/import are gated.
#   Missing X402_WALLET_ADDRESS or ZYND_AGENT_ID returns HTTP 503 (misconfigured).
X402_ENABLED=false
X402_PRICE_USDC=0.01
X402_WALLET_ADDRESS=0x...             # Required when X402_ENABLED=true
X402_PAYMENT_HEADER=x-payment        # HTTP header name (default: x-payment)
ZYND_API_KEY=...                      # For payment verification
ZYND_AGENT_ID=...                     # Required when X402_ENABLED=true
ZYND_VERIFY_ENDPOINT=https://api.zynd.ai/v1/payments/verify

# ── Superplane (workflow event tracking) ──────────────────────────────────────
# SUPERPLANE_ENABLED=false (default): no external calls made.
# SUPERPLANE_ENABLED=true: POSTs filemind.investigation.completed after each query.
SUPERPLANE_ENABLED=false
SUPERPLANE_API_TOKEN=...
SUPERPLANE_CANVAS_ID=...
SUPERPLANE_ENDPOINT=https://api.superplane.dev/v1/events

# ── File system limits ────────────────────────────────────────────────────────
MAX_FILE_SIZE_KB=500
MAX_TREE_DEPTH=6
ALLOWED_EXTENSIONS=.ts,.tsx,.js,.jsx,.py,.go,.rs,.java,.md,.json,.yaml,.yml,.toml,.env.example
