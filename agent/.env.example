# ─── Core (required) ──────────────────────────────────────────────────────────

# Anthropic API key — required. Powers the agent loop (Opus 4.5) and summarizer (Haiku 4.5).
ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the Express server listens on (default: 3001)
PORT=3001

# Node environment — "development" | "production" | "test"
NODE_ENV=development

# ─── File system limits ───────────────────────────────────────────────────────

# Maximum size of a single file the agent will read, in kilobytes (default: 500)
MAX_FILE_SIZE_KB=500

# Maximum depth for the tree tool when traversing directories (default: 6)
MAX_TREE_DEPTH=6

# Comma-separated list of allowed file extensions (leave unset to use built-in defaults)
# Default: .ts .tsx .js .jsx .py .go .rs .java .md .json .yaml .yml .toml
ALLOWED_EXTENSIONS=.ts,.tsx,.js,.jsx,.py,.go,.rs,.java,.md,.json,.yaml,.yml,.toml

# ─── Apify — remote repo ingestion (Phase 5) ─────────────────────────────────

# Apify API token — if set with APIFY_ACTOR_ID, remote import uses Apify instead of GitHub fallback
APIFY_API_TOKEN=apify_api_...

# Apify actor ID for the filemind-repo-fetcher actor
APIFY_ACTOR_ID=username~filemind-repo-importer

# GitHub personal access token — optional; raises API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=ghp_...

# ─── Zynd AI / x402 micropayments (Phase 6) ──────────────────────────────────

# Set to "true" to enforce x402 payment on /query and /repos/import routes (default: false)
X402_ENABLED=false

# Price per query in USDC (e.g. "0.01" = 1 cent)
X402_PRICE_USDC=0.01

# Wallet address that receives USDC payments
X402_WALLET_ADDRESS=0x...

# HTTP header name the client must send with the payment token (default: x-payment)
X402_PAYMENT_HEADER=x-payment

# Zynd API key — required when X402_ENABLED=true; used to verify payment tokens
ZYND_API_KEY=zynd_...

# Zynd agent ID registered at deployer.zynd.ai — required when X402_ENABLED=true
ZYND_AGENT_ID=agent-...

# Zynd payment verification endpoint (default: Zynd production URL; override for staging)
# ZYND_VERIFY_ENDPOINT=https://api.zynd.ai/v1/payments/verify

# ─── Superplane workflow events (Phase 6) ─────────────────────────────────────

# Set to "true" to emit filemind.investigation.completed events to Superplane after each query
SUPERPLANE_ENABLED=false

# Superplane API token for Bearer authentication — required when SUPERPLANE_ENABLED=true
SUPERPLANE_API_TOKEN=sp_...

# Superplane canvas ID to associate events with — required when SUPERPLANE_ENABLED=true
SUPERPLANE_CANVAS_ID=canvas-...

# Superplane event endpoint — override default if using a non-production environment
# SUPERPLANE_ENDPOINT=https://api.superplane.dev/v1/events
