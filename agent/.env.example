# ─── Core (required) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── File system limits ───────────────────────────────────────────────────────
MAX_FILE_SIZE_KB=500
MAX_TREE_DEPTH=6

# File extensions the agent is allowed to read (comma-separated)
ALLOWED_EXTENSIONS=.ts,.tsx,.js,.jsx,.py,.go,.rs,.java,.md,.json,.yaml,.yml,.toml,.env.example

# ─── Apify — remote repo ingestion (Phase 5) ─────────────────────────────────
# Leave unset to fall back to direct GitHub API calls (no Apify account needed)
APIFY_API_TOKEN=apify_api_...
APIFY_ACTOR_ID=username~filemind-repo-importer

# ─── GitHub API ───────────────────────────────────────────────────────────────
# Optional: raises rate limit from 60 → 5000 req/hr when set
GITHUB_TOKEN=ghp_...

# ─── Zynd AI / x402 micropayments (Phase 6) ──────────────────────────────────
# Keep false until final demo — enabling adds a payment gate to /query and /repos
X402_ENABLED=false

# USDC price per query (e.g. 0.01 = 1 cent)
X402_PRICE_USDC=0.01

# Your USDC wallet address to receive payments
X402_WALLET_ADDRESS=0x...

# Zynd API key and registered agent ID (from deployer.zynd.ai)
ZYND_API_KEY=...
ZYND_AGENT_ID=...

# Which request header carries the payment proof (default: x-payment)
X402_PAYMENT_HEADER=x-payment

# Zynd payment verification endpoint (default shown; override if using staging)
# ZYND_VERIFY_ENDPOINT=https://api.zynd.ai/v1/payments/verify

# ─── Superplane workflow events (Phase 6) ─────────────────────────────────────
# Emits filemind.investigation.completed events after each successful query
SUPERPLANE_ENABLED=false
SUPERPLANE_API_TOKEN=...
SUPERPLANE_CANVAS_ID=...

# Override the default Superplane events endpoint if needed
# SUPERPLANE_ENDPOINT=https://api.superplane.dev/v1/events
